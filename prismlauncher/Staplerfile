package() {
    cd "${srcdir}"

    mkdir -p "${pkgdir}/opt/prismlauncher"
    tar --no-same-owner --no-same-permissions -xzf prismlauncher.tar.gz -C "${pkgdir}/opt/prismlauncher"
    rm -f "${pkgdir}/opt/prismlauncher/portable.txt"

    chmod 755 "${pkgdir}/opt/prismlauncher/bin/prismlauncher"
    chmod 755 "${pkgdir}/opt/prismlauncher/bin/prismlauncher_updater"

    mkdir -p "${pkgdir}/usr/bin"
    ln -sf /opt/prismlauncher/bin/prismlauncher "${pkgdir}/usr/bin/prismlauncher"

    install -Dm644 "${pkgdir}/opt/prismlauncher/share/applications/org.prismlauncher.PrismLauncher.desktop" \
        "${pkgdir}/usr/share/applications/org.prismlauncher.PrismLauncher.desktop"
    install -Dm644 "${pkgdir}/opt/prismlauncher/share/metainfo/org.prismlauncher.PrismLauncher.metainfo.xml" \
        "${pkgdir}/usr/share/metainfo/org.prismlauncher.PrismLauncher.metainfo.xml"
    install -Dm644 "${pkgdir}/opt/prismlauncher/share/mime/packages/org.prismlauncher.PrismLauncher.xml" \
        "${pkgdir}/usr/share/mime/packages/org.prismlauncher.PrismLauncher.xml"
    install -Dm644 "${pkgdir}/opt/prismlauncher/share/man/man6/prismlauncher.6" \
        "${pkgdir}/usr/share/man/man6/prismlauncher.6"

    cp -a "${pkgdir}/opt/prismlauncher/share/icons" "${pkgdir}/usr/share/icons"
}

files() {
    files-find-binary
    files-find-desktop
    files-find \
        "/opt" \
        "/opt/prismlauncher" \
        "/opt/prismlauncher/**/*" \
        "/usr/share/icons/hicolor/*/apps/org.prismlauncher.PrismLauncher.*" \
        "/usr/share/man/man6/prismlauncher.6" \
        "/usr/share/metainfo/org.prismlauncher.PrismLauncher.metainfo.xml" \
        "/usr/share/mime/packages/org.prismlauncher.PrismLauncher.xml"
}
