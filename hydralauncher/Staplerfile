name='hydralauncher'
version='3.9.9'
release=2
summary='Open-source game launcher with embedded BitTorrent support'
summary_ru='Открытый игровой лаунчер со встроенной поддержкой BitTorrent'
group='Games/Other'
desc='Hydra Launcher is an open-source gaming platform with a native Electron client, account features and an embedded BitTorrent client.'
desc_ru='Hydra Launcher — открытая игровая платформа с нативным Electron-клиентом, учетными записями и встроенным BitTorrent-клиентом.'
homepage='https://hydralauncher.app/dl/'
maintainer='Hydra Launcher contributors <https://github.com/hydralauncher/hydra>'

architectures=('amd64')

license=('MIT')

provides=('hydralauncher' 'hydra-launcher')
replaces=('hydralauncher' 'hydra-launcher')

auto_reqprov_method="dirty"
auto_req=0
auto_prov=0

deps=()
deps_debian=('libgtk-3-0' 'libnotify4' 'libnss3' 'libxss1' 'libxtst6' 'xdg-utils' 'libatspi2.0-0' 'libuuid1' 'libsecret-1-0')
deps_ubuntu=("${deps_debian[@]}")
deps_fedora=('gtk3' 'libnotify' 'nss' 'libXScrnSaver' 'libXtst' 'xdg-utils' 'at-spi2-core' 'libuuid' 'libsecret')
deps_arch=('gtk3' 'libnotify' 'nss' 'libxss' 'libxtst' 'xdg-utils' 'at-spi2-core' 'util-linux-libs' 'libsecret')
deps_opensuse=('gtk3' 'libnotify4' 'mozilla-nss' 'libXScrnSaver1' 'libXtst6' 'xdg-utils' 'at-spi2-core' 'libuuid1' 'libsecret-1-0')
deps_altlinux=('libgtk+3' 'libnotify' 'libnss' 'libXScrnSaver' 'libXtst' 'xdg-utils' 'at-spi2-core' 'libuuid' 'libsecret')

sources=(
    "https://github.com/hydralauncher/hydra/releases/download/v${version}/hydralauncher_${version}_amd64.deb?~archive=false&~name=hydralauncher.deb"
)

checksums=(
    '66a3c3dd16fecd1655bbbcb82a004ef1fad0339bf733b3ac1345c801531e4ba5'
)

scripts=(
    ['postinstall']='postinstall.sh'
    ['postremove']='postremove.sh'
)

package() {
    cd "${srcdir}"

    mkdir -p "${srcdir}/extracted"
    ar x hydralauncher.deb
    tar -xf data.tar.* -C "${srcdir}/extracted"

    for path in opt usr; do
        if [[ -d "${srcdir}/extracted/${path}" ]]; then
            mkdir -p "${pkgdir}/${path}"
            cp -a "${srcdir}/extracted/${path}/." "${pkgdir}/${path}/"
        fi
    done

    mkdir -p "${pkgdir}/usr/bin"
    ln -sf /opt/Hydra/hydralauncher "${pkgdir}/usr/bin/hydralauncher"

    if [[ -f "${pkgdir}/opt/Hydra/chrome-sandbox" ]]; then
        chmod 0755 "${pkgdir}/opt/Hydra/chrome-sandbox"
    fi
}

files() {
    if [[ -d "${pkgdir}/usr" ]]; then
        files-find "/usr/**/*"
    fi
    if [[ -d "${pkgdir}/opt" ]]; then
        files-find "/opt/**/*"
    fi
}
