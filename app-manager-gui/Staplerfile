name='app-manager-gui'
version='1.2.5+3'
release=1
summary='ADB-based Android app management GUI'
summary_ru='GUI для управления Android-приложениями через ADB'
group='Development/Tools'
desc='App Manager GUI is a cross-platform desktop tool for viewing, exporting, installing, removing and debloating Android applications through ADB.'
desc_ru='App Manager GUI — кроссплатформенный desktop-инструмент для просмотра, экспорта, установки, удаления и очистки Android-приложений через ADB.'
homepage='https://github.com/BlassGO/AppManager-GUI'
maintainer='BlassGO <https://github.com/BlassGO>'

architectures=('amd64')

license=('GPL-3.0-only')

provides=('app-manager-gui' 'appmanager-gui' 'android-app-manager' 'app-manager')
replaces=('app-manager-gui' 'appmanager-gui' 'android-app-manager' 'app-manager')

auto_reqprov_method="dirty"
auto_req=0
auto_prov=0

deps=()
deps_debian=('adb | android-tools-adb' 'libgtk-3-0' 'libstdc++6' 'libglib2.0-0' 'libxkbcommon0' 'libwayland-client0' 'fontconfig')
deps_ubuntu=("${deps_debian[@]}")
deps_fedora=('android-tools' 'gtk3' 'libstdc++' 'glib2' 'libxkbcommon' 'libwayland-client' 'fontconfig')
deps_arch=('android-tools' 'gtk3' 'gcc-libs' 'glib2' 'libxkbcommon' 'wayland' 'fontconfig')
deps_opensuse=('android-tools' 'gtk3' 'libstdc++6' 'glib2' 'libxkbcommon0' 'libwayland-client0' 'fontconfig')
deps_altlinux=('android-tools' 'libgtk+3' 'libstdc++6' 'glib2' 'libxkbcommon' 'libwayland-client' 'fontconfig')

release_tag="v${version/+/%2B}"

sources=(
    "https://github.com/BlassGO/AppManager-GUI/releases/download/${release_tag}/app_manager_linux_x64.tar.gz?~archive=false&~name=app_manager_linux_x64.tar.gz"
    "local:///app-manager-gui.png"
    "local:///LICENSE.upstream"
)

checksums=(
    'd7da42814b9ce2e25a6d814363cedf80a00544874e882dfc0f6c2c9a16a7aeeb'
    'cc17af0d33ccdac5a110fad923a863a5598a3d2b947f7d16f4582299ee41f370'
    '605e9047a563c5c8396ffb18232aa4304ec56586aee537c45064c6fb425e44ad'
)

scripts=(
    ['postinstall']='postinstall.sh'
    ['postremove']='postremove.sh'
)

package() {
    cd "${srcdir}"

    rm -rf app-manager-gui
    mkdir -p app-manager-gui
    tar -xzf app_manager_linux_x64.tar.gz -C app-manager-gui

    install -dm755 "${pkgdir}/opt/app-manager-gui"
    cp -a app-manager-gui/. "${pkgdir}/opt/app-manager-gui/"
    chmod 755 "${pkgdir}/opt/app-manager-gui/app_manager"

    install -Dm755 /dev/stdin "${pkgdir}/usr/bin/app-manager-gui" <<'EOF'
#!/bin/bash
set -e
cd /opt/app-manager-gui
exec ./app_manager "$@"
EOF

    install -Dm755 /dev/stdin "${pkgdir}/usr/bin/app_manager" <<'EOF'
#!/bin/bash
set -e
exec /usr/bin/app-manager-gui "$@"
EOF

    install -Dm644 app-manager-gui.png \
        "${pkgdir}/usr/share/icons/hicolor/512x512/apps/app-manager-gui.png"
    install -Dm644 LICENSE.upstream \
        "${pkgdir}/usr/share/licenses/app-manager-gui/LICENSE"

    install -Dm644 /dev/stdin "${pkgdir}/usr/share/applications/app-manager-gui.desktop" <<'EOF'
[Desktop Entry]
Name=App Manager GUI
Comment=Manage Android apps through ADB
Comment[ru]=Управление Android-приложениями через ADB
Exec=app-manager-gui
Terminal=false
Type=Application
Icon=app-manager-gui
Categories=Development;
Keywords=adb;android;apps;debloat;packages;
StartupNotify=true
StartupWMClass=app_manager
EOF
}

files() {
    files-find-binary
    files-find-desktop
    files-find-license
    files-find \
        "/opt/app-manager-gui/**/*" \
        "/usr/share/icons/hicolor/512x512/apps/app-manager-gui.png"
}
