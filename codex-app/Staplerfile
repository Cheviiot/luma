package() {
    cd "${srcdir}"

    tar -xzf codex-app.tar.gz
    src="$(find "${srcdir}" -maxdepth 1 -type d -name "codex-app-${version}-x64" | head -1)"

    install -dm755 "${pkgdir}/opt/codex-app"
    cp -a "${src}/." "${pkgdir}/opt/codex-app/"

    # Отключаем стандартное меню Electron на Linux/Windows до загрузки основного codex.asar.
    python3 - "${pkgdir}/opt/codex-app/resources/app.asar" "${version}" <<'PY'
import hashlib
import json
import struct
import sys
from pathlib import Path

asar_path = Path(sys.argv[1])
app_version = sys.argv[2]

bootstrap = b'''"use strict";
const path = require("path");
const electron = require("electron");

const { app, Menu } = electron;

function disableNativeMenus() {
  const setNullMenu = () => {
    try {
      Menu.setApplicationMenu(null);
    } catch {}
  };

  const originalSetApplicationMenu = Menu.setApplicationMenu.bind(Menu);
  Menu.setApplicationMenu = () => originalSetApplicationMenu(null);

  app.on("browser-window-created", (_event, window) => {
    try {
      window.setMenu(null);
    } catch {}
    try {
      window.setMenuBarVisibility(false);
    } catch {}
  });

  setNullMenu();
}

disableNativeMenus();

process.env.ELECTRON_FORCE_IS_PACKAGED = "1";
process.env.NODE_ENV = "production";
process.env.CODEX_CLI_PATH = path.join(process.resourcesPath, "codex");
require(path.join(process.resourcesPath, "codex.asar"));
'''

package_json = json.dumps(
    {
        "name": "codex-app",
        "private": True,
        "version": app_version,
        "main": "bootstrap.js",
        "description": "Codex app for Linux",
        "author": "Boria138",
    },
    separators=(",", ":"),
).encode()

entries = [
    ("bootstrap.js", bootstrap),
    ("package.json", package_json),
]

header_files = {}
offset = 0
for name, content in entries:
    digest = hashlib.sha256(content).hexdigest()
    header_files[name] = {
        "size": len(content),
        "offset": str(offset),
        "integrity": {
            "algorithm": "SHA256",
            "hash": digest,
            "blockSize": 4194304,
            "blocks": [digest],
        },
    }
    offset += len(content)

header = json.dumps({"files": header_files}, separators=(",", ":")).encode()
header_padded_size = (len(header) + 3) & ~3
asar_path.write_bytes(
    struct.pack("<IIII", 4, header_padded_size + 8, header_padded_size + 4, len(header))
    + header
    + (b"\0" * (header_padded_size - len(header)))
    + b"".join(content for _, content in entries)
)
PY

    chmod 755 "${pkgdir}/opt/codex-app/codex-app" 2>/dev/null || true
    chmod 755 "${pkgdir}/opt/codex-app/resources/codex" 2>/dev/null || true
    if [[ -f "${pkgdir}/opt/codex-app/chrome-sandbox" ]]; then
        chmod 0755 "${pkgdir}/opt/codex-app/chrome-sandbox"
    fi

    mkdir -p "${pkgdir}/usr/bin"
    ln -sf /opt/codex-app/codex-app "${pkgdir}/usr/bin/codex-app"

    install -Dm644 codex-app.png \
        "${pkgdir}/usr/share/icons/hicolor/512x512/apps/codex-app.png"

    install -Dm644 "${src}/LICENSE.electron.txt" \
        "${pkgdir}/usr/share/licenses/codex-app/LICENSE.electron.txt"
    install -Dm644 "${src}/LICENSES.chromium.html" \
        "${pkgdir}/usr/share/licenses/codex-app/LICENSES.chromium.html"

    install -Dm644 /dev/stdin "${pkgdir}/usr/share/applications/codex-app.desktop" <<'EOF'
[Desktop Entry]
Name=Codex App
Comment=Desktop coding agent client
Comment[ru]=Десктопный клиент coding agent
Exec=/usr/bin/codex-app %U
Terminal=false
Type=Application
Icon=codex-app
Categories=Development;IDE;
StartupWMClass=codex-app
EOF
}

files() {
    files-find "/opt/codex-app/**/*"
    files-find-binary
    files-find-desktop
    files-find "/usr/share/icons/hicolor/*/apps/codex-app.png"
    files-find "/usr/share/licenses/codex-app/*"
}
