import hashlib
import json
import struct
import sys
from pathlib import Path

asar_path = Path(sys.argv[1])
app_version = sys.argv[2]

bootstrap = '''"use strict";
const fs = require("fs");
const os = require("os");
const path = require("path");
const electron = require("electron");

const { app, Menu } = electron;

function firstExistingDirectory(paths) {
  for (const candidate of paths) {
    if (!candidate) {
      continue;
    }
    try {
      if (fs.statSync(candidate).isDirectory()) {
        return candidate;
      }
    } catch {}
  }
  return "";
}

function configureLocalizedDocumentsPath() {
  const home = os.homedir();
  const envDocuments = process.env.CODEX_APP_DOCUMENTS_DIR;
  const configuredDocuments = firstExistingDirectory([
    envDocuments,
    path.join(home, "Документы"),
  ]);

  if (!configuredDocuments) {
    return;
  }

  process.env.XDG_DOCUMENTS_DIR = configuredDocuments;
  try {
    app.setPath("documents", configuredDocuments);
  } catch {}
}

function disableNativeMenus() {
  const setNullMenu = () => {
    try {
      Menu.setApplicationMenu(null);
    } catch {}
  };

  const originalSetApplicationMenu = Menu.setApplicationMenu.bind(Menu);
  Menu.setApplicationMenu = () => originalSetApplicationMenu(null);

  app.on("browser-window-created", (_event, window) => {
    try {
      window.setMenu(null);
    } catch {}
    try {
      window.setMenuBarVisibility(false);
    } catch {}
  });

  setNullMenu();
}

disableNativeMenus();
configureLocalizedDocumentsPath();

process.env.ELECTRON_FORCE_IS_PACKAGED = "1";
process.env.NODE_ENV = "production";
process.env.CODEX_CLI_PATH = path.join(process.resourcesPath, "codex");
require(path.join(process.resourcesPath, "codex.asar"));
'''.encode()

