    pattern = re.compile(rf'("{re.escape(key)}":`)([^`]*)(`)')
    match = pattern.search(text)
    if not match or match.group(2) == new_value:
        return text, False
    return text[: match.start(2)] + new_value + text[match.end(2) :], True


def template_value(text: str, key: str) -> str | None:
    match = re.search(rf'"{re.escape(key)}":`([^`]*)`', text)
    return None if match is None else match.group(1)


def patch_linux_ui_text(path: str, text: str) -> tuple[str, list[str]]:
    if not path.startswith("webview/assets/"):
        return text, []

    changes = []
    for key, fallback_key in linux_ui_fallback_keys:
        fallback_value = template_value(text, fallback_key)
        if fallback_value is None:
            continue
        text, changed = replace_template_value(text, key, fallback_value)
        if changed:
            changes.append(f"linux ui windows fallback {key}: {path}")

    for key in linux_ui_pc_keys:
        value = template_value(text, key)
        if value is None:
            continue
        pc_value = value.replace("Mac", "PC").replace("macOS", "Linux")
        if "webview/assets/ru-RU-" in path:
            pc_value = pc_value.replace("PC", "–Я–Ъ")
            pc_value = pc_value.replace("–њ—А–Є–ї–Њ–ґ–µ–љ–Є—П –Я–Ъ, –њ–Њ–Ї–∞ –Њ–љ –Ј–∞–±–ї–Њ–Ї–Є—А–Њ–≤–∞–љ", "–њ—А–Є–ї–Њ–ґ–µ–љ–Є—П –Я–Ъ, –њ–Њ–Ї–∞ –Ї–Њ–Љ–њ—М—О—В–µ—А –Ј–∞–±–ї–Њ–Ї–Є—А–Њ–≤–∞–љ")
        text, changed = replace_template_value(text, key, pc_value)
        if changed:
            changes.append(f"linux ui pc wording {key}: {path}")

    return text, changes


def rebuild_node(node: dict, prefix: str = "") -> dict:
    rebuilt = {}
    for name, child in node.get("files", {}).items():
        path = f"{prefix}/{name}" if prefix else name
        if "files" in child:
            rebuilt[name] = {
                **{key: value for key, value in child.items() if key != "files"},
                "files": rebuild_node(child, path),
            }
            continue

        entry = copy.deepcopy(child)
        if entry.get("unpacked"):
            rebuilt[name] = entry
            continue

        offset = int(entry["offset"])
        size = int(entry["size"])
        content = data[base_offset + offset : base_offset + offset + size]

        if path == "webview/apps/file-explorer.png":
            content = linux_file_manager_icon
            entry["size"] = len(content)
            entry["integrity"] = integrity_for(content, entry.get("integrity", {}).get("blockSize", 4194304))
            matched_replacements.append(f"linux file manager icon: {path}")

        text = None
        for label, old, new in replacements:
            old_bytes = old.encode("utf-8")
            if old_bytes not in content:
                continue
            if text is None:
                text = content.decode("utf-8")
            count = text.count(old)
            if count != 1:
                raise SystemExit(f"expected one {label} match in {path}, got {count}")
            content = text.replace(old, new).encode("utf-8")
            text = content.decode("utf-8")
            entry["size"] = len(content)
            entry["integrity"] = integrity_for(content, entry.get("integrity", {}).get("blockSize", 4194304))
            matched_replacements.append(f"{label}: {path}")

        if text is None and path.startswith("webview/assets/"):
            try:
                text = content.decode("utf-8")
            except UnicodeDecodeError:
                text = None

        if text is not None:
            text, linux_ui_changes = patch_linux_ui_text(path, text)
            if linux_ui_changes:
                content = text.encode("utf-8")
                entry["size"] = len(content)
                entry["integrity"] = integrity_for(content, entry.get("integrity", {}).get("blockSize", 4194304))
                matched_replacements.extend(linux_ui_changes)

        entry["offset"] = str(len(output))
        output.extend(content)
        rebuilt[name] = entry

    return rebuilt


