#!/bin/bash

set -e

find_documents_dir() {
    local xdg_dir russian_dir

    russian_dir="${HOME}/Документы"

    if command -v xdg-user-dir >/dev/null 2>&1; then
        xdg_dir="$(xdg-user-dir DOCUMENTS 2>/dev/null || true)"
        if [[ -n "${xdg_dir}" && "${xdg_dir}" != "${HOME}/Documents" && -d "${xdg_dir}" ]]; then
            printf '%s\n' "${xdg_dir}"
            return
        fi
    fi

    if [[ -d "${russian_dir}" ]]; then
        printf '%s\n' "${russian_dir}"
        return
    fi

    if [[ -n "${xdg_dir:-}" && -d "${xdg_dir}" ]]; then
        printf '%s\n' "${xdg_dir}"
    fi
}

documents_dir="$(find_documents_dir)"
if [[ -n "${documents_dir}" ]]; then
    export CODEX_APP_DOCUMENTS_DIR="${documents_dir}"
    export XDG_DOCUMENTS_DIR="${documents_dir}"
fi

exec /opt/codex-app/codex-app "$@"
