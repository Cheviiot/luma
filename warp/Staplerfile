sources=(
    "https://app.warp.dev/download?package=deb&~archive=false&~name=warp-terminal.deb"
)

sources_arm64=(
    "https://app.warp.dev/download?package=deb_arm64&~archive=false&~name=warp-terminal.deb"
)

checksums=(
    '203d8df452816d3754ba80ae81bcca5a18034e2e4c14f2a0f1ea4eeb3fd1eb9f'
)

checksums_arm64=(
    '084d4d23dad31afce0cafc7cc8a611f6682da7368fe255b38ab61e69b04d8d14'
)

scripts=(
    ['postinstall']='postinstall.sh'
    ['postremove']='postremove.sh'
)

package() {
    cd "${srcdir}"

    mkdir -p "${srcdir}/extracted"
    ar x warp-terminal.deb
    tar -xf data.tar.* -C "${srcdir}/extracted"

    for path in opt usr etc; do
        if [[ -d "${srcdir}/extracted/${path}" ]]; then
            mkdir -p "${pkgdir}/${path}"
            cp -a "${srcdir}/extracted/${path}/." "${pkgdir}/${path}/"
        fi
    done

    # Upstream .deb creates this in postinst; keep Luma package self-contained.
    mkdir -p "${pkgdir}/usr/bin"
    ln -sf /opt/warpdotdev/warp-terminal/warp "${pkgdir}/usr/bin/warp"
}

files() {
    if [[ -d "${pkgdir}/usr" ]]; then
        files-find "/usr/**/*"
    fi
    if [[ -d "${pkgdir}/opt" ]]; then
        files-find "/opt/**/*"
    fi
    if [[ -d "${pkgdir}/etc" ]]; then
        files-find "/etc/**/*"
    fi
}
