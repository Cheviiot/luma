desc='Warp is a modern Rust-based terminal with AI features, command sharing and team-oriented developer workflows.'
desc_ru='Warp — современный терминал на Rust с AI-функциями, обменом командами и рабочими процессами для разработчиков.'
homepage='https://www.warp.dev/'
maintainer='Warp Linux Maintainers <linux-maintainers@warp.dev>'

architectures=('amd64' 'arm64')

license=('AGPL-3.0-only' 'MIT')

provides=('warp-terminal')
