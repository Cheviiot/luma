deps=()
deps_debian=('fontconfig' 'libegl1' 'libwayland-client0' 'libwayland-egl1' 'libx11-6' 'libxcb1' 'libxcursor1' 'libxi6' 'libxkbcommon-x11-0' 'zlib1g' 'libgl1-mesa-dri' 'adwaita-icon-theme')
deps_ubuntu=("${deps_debian[@]}")
deps_fedora=('fontconfig' 'mesa-libEGL' 'wayland' 'libX11' 'libxcb' 'libXcursor' 'libXi' 'libxkbcommon-x11' 'zlib' 'mesa-dri-drivers' 'adwaita-icon-theme')
deps_arch=('fontconfig' 'libglvnd' 'wayland' 'libx11' 'libxcb' 'libxcursor' 'libxi' 'libxkbcommon-x11' 'zlib' 'mesa' 'adwaita-icon-theme')
deps_opensuse=('fontconfig' 'libEGL1' 'libwayland-client0' 'libwayland-egl1' 'libX11-6' 'libxcb1' 'libXcursor1' 'libXi6' 'libxkbcommon-x11-0' 'libz1' 'Mesa-dri' 'adwaita-icon-theme')
