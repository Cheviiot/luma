package() {
    cd "${srcdir}/hermes-agent-${version}"

    python3 - <<'PY'
import sys

if sys.version_info < (3, 11) or sys.version_info >= (3, 14):
    raise SystemExit("Hermes Agent requires Python >=3.11,<3.14")
PY

    install -dm755 "${pkgdir}/opt/hermes-agent"

    python3 -m venv "${pkgdir}/opt/hermes-agent/venv"
    "${pkgdir}/opt/hermes-agent/venv/bin/python" -m pip install --upgrade pip setuptools wheel
    "${pkgdir}/opt/hermes-agent/venv/bin/python" -m pip install '.[all]'

    export npm_config_nodedir=/usr

    npm ci \
        --fetch-retries=5 \
        --fetch-retry-factor=2 \
        --fetch-retry-mintimeout=20000 \
        --fetch-retry-maxtimeout=120000 \
        --network-timeout=300000
    (
        cd apps/desktop
        GITHUB_SHA="${source_commit}" \
            GITHUB_REF_NAME="v${version}" \
            CSC_IDENTITY_AUTO_DISCOVERY=false \
            npm run pack
    )

    cp -a apps/desktop/release/linux-unpacked "${pkgdir}/opt/hermes-agent/desktop"
    chmod 755 "${pkgdir}/opt/hermes-agent/desktop/Hermes"
    chmod 4755 "${pkgdir}/opt/hermes-agent/desktop/chrome-sandbox" 2>/dev/null || true

    install -dm755 "${pkgdir}/usr/bin"
    cat >"${pkgdir}/usr/bin/hermes" <<'EOF'
#!/bin/bash
unset PYTHONPATH
unset PYTHONHOME
export PYTHONNOUSERSITE=1
exec /opt/hermes-agent/venv/bin/hermes "$@"
EOF
    chmod 755 "${pkgdir}/usr/bin/hermes"

    cat >"${pkgdir}/usr/bin/hermes-desktop" <<'EOF'
#!/bin/bash
unset PYTHONPATH
unset PYTHONHOME
export HERMES_DESKTOP_HERMES="${HERMES_DESKTOP_HERMES:-/usr/bin/hermes}"
export HERMES_DESKTOP_IGNORE_EXISTING="${HERMES_DESKTOP_IGNORE_EXISTING:-1}"
exec /opt/hermes-agent/desktop/Hermes "$@"
EOF
    chmod 755 "${pkgdir}/usr/bin/hermes-desktop"

    python3 - "${pkgdir}/opt/hermes-agent/venv/bin" <<'PY'
from pathlib import Path
import sys

bin_dir = Path(sys.argv[1])
for path in bin_dir.iterdir():
    if not path.is_file():
        continue
    try:
        data = path.read_bytes()
    except OSError:
        continue
    if not data.startswith(b"#!") or b"/opt/hermes-agent/venv/bin/python" in data.splitlines()[0]:
        continue
    lines = data.splitlines(keepends=True)
    if b"/opt/hermes-agent/venv/bin/python" not in lines[0] and b"/hermes-agent/venv/bin/python" in lines[0]:
        lines[0] = b"#!/opt/hermes-agent/venv/bin/python\n"
        path.write_bytes(b"".join(lines))
PY

    install -dm755 "${pkgdir}/usr/share/applications"
    cat >"${pkgdir}/usr/share/applications/hermes-agent.desktop" <<'EOF'
[Desktop Entry]
Name=Hermes Agent
Comment=Self-improving AI agent desktop client
Comment[ru]=Десктопный клиент самоулучшающегося AI-агента Hermes
Exec=hermes-desktop %U
Terminal=false
Type=Application
Icon=hermes-agent
StartupWMClass=Hermes
Categories=Development;Utility;
MimeType=x-scheme-handler/hermes;
EOF

    install -dm755 "${pkgdir}/usr/share/icons/hicolor/1024x1024/apps"
    install -Dm644 apps/desktop/assets/icon.png "${pkgdir}/usr/share/icons/hicolor/1024x1024/apps/hermes-agent.png"

    install -dm755 "${pkgdir}/usr/share/licenses/hermes-agent"
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/hermes-agent/LICENSE.upstream"
}

files() {
    files-find-binary
    files-find-desktop
    files-find \
        "/opt/hermes-agent/**/*" \
        "/usr/share/icons/hicolor/*/apps/hermes-agent.png" \
        "/usr/share/licenses/hermes-agent/LICENSE.upstream"
}
